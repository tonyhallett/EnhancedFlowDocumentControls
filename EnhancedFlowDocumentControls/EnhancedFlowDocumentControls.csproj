<Project Sdk="Microsoft.NET.Sdk.WindowsDesktop">
  <PropertyGroup>
    <TargetFrameworks>net46;net461;net471;net472;net48</TargetFrameworks>
    <UseWPF>true</UseWPF>
    <Authors>TonyHUK</Authors>
    <Description> Enhanced FlowDocumentReader, FlowDocumentScrollViewer and FlowDocumentPageViewer for custom find toolbars.</Description>
    <Copyright>Copyright © 2025 Tony Hallett</Copyright>
    <RepositoryUrl>https://github.com/tonyhallett/EnhancedFlowDocumentControls.git</RepositoryUrl>
    <PackageTags>FlowDocument;Find;Toolbar;FlowDocumentReader;FlowDocumentScrollViewer;FlowDocumentPageViewer</PackageTags>
    <PackageLicenseExpression>MIT</PackageLicenseExpression>
    <PackageReadmeFile>README.md</PackageReadmeFile>
    <PackageProjectUrl>https://github.com/tonyhallett/EnhancedFlowDocumentControls</PackageProjectUrl>
    <Title>Enhanced Flow Document Controls, custom find toolbar.</Title>
    <GeneratePackageOnBuild>True</GeneratePackageOnBuild>
  </PropertyGroup>
  <ItemGroup>
    <None Include="..\README.md">
      <Pack>True</Pack>
      <PackagePath>\</PackagePath>
    </None>
  </ItemGroup>
</Project>